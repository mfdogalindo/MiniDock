MINIDOCK_ADDRESS=127.0.0.1:8080
MINIDOCK_DATABASE_PATH=./data/minidock.db
MINIDOCK_ENVIRONMENT=development
MINIDOCK_DOMAIN=localhost
MINIDOCK_WORKSPACE_PATH=./data/apps
MINIDOCK_LOG_PATH=./data/logs
MINIDOCK_DOCKER_NETWORK=minidock
# La red de workloads se crea como bridge interno sin salida externa. No la
# conectes a redes de aplicaciones no administradas.
MINIDOCK_DOCKER_NETWORK_SUBNET=172.31.251.0/24
MINIDOCK_CADDY_WORKLOAD_IP=172.31.251.2
MINIDOCK_DOCKER_PROXY_LOG=warning
MINIDOCK_RUNTIME=auto
# El proveedor de claves se desbloquea explícitamente desde la UI. No configures
# una contraseña en variables o archivos: MiniDock no admite auto-desbloqueo.
# Un secreto compartido configurado también en GitHub para validar webhooks.
MINIDOCK_GITHUB_WEBHOOK_SECRET=
# Límite persistente por aplicación para pushes correctamente firmados. No se
# usa X-Forwarded-For: MiniDock no confía en cabeceras de cliente sin un proxy
# autenticado configurado explícitamente.
MINIDOCK_GITHUB_WEBHOOK_RATE_LIMIT=30
MINIDOCK_GITHUB_WEBHOOK_RATE_WINDOW=1m
# URL opcional para notificar cada resultado (Discord/Slack vía webhook, etc.).
MINIDOCK_NOTIFICATION_WEBHOOK=
# Umbrales de observabilidad y retención conservadora (en días/imágenes).
MINIDOCK_DISK_ALERT_PERCENT=85
MINIDOCK_CERTIFICATE_ALERT_DAYS=21
MINIDOCK_RETENTION_DAYS=30
MINIDOCK_RETAINED_IMAGES=3
# Directorio del host permitido para repositorios locales (móntalo como /repos
# de solo lectura cuando uses Docker Compose).
# Por defecto: carpeta de usuario (~) en macOS/Linux/Windows.
MINIDOCK_LOCAL_REPOSITORIES_PATH=
# GitHub App opcional: la clave privada se monta como archivo de solo lectura.
MINIDOCK_GITHUB_APP_ID=
MINIDOCK_GITHUB_APP_PRIVATE_KEY_PATH=
MINIDOCK_GITHUB_API_URL=https://api.github.com
# Los tiempos usan unidades Go (por ejemplo 30s, 5m); los tamaños son bytes.
MINIDOCK_SOURCE_TIMEOUT=5m
MINIDOCK_BUILD_TIMEOUT=20m
MINIDOCK_START_TIMEOUT=2m
MINIDOCK_HEALTH_TIMEOUT=30s
MINIDOCK_WORKSPACE_MAX_BYTES=2147483648
MINIDOCK_LOG_MAX_BYTES=20971520
MINIDOCK_MAX_CONCURRENT_DEPLOYMENTS=1
# Ajustes avanzados del sidecar administrado. No pongas tokens de Cloudflare en
# este archivo; se introducen en la UI y se guardan cifrados en SQLite.
MINIDOCK_CLOUDFLARED_IMAGE=cloudflare/cloudflared:2026.7.2
MINIDOCK_CLOUDFLARED_NETWORK=minidock-edge
# Dominio administrativo y URL del proxy que verifica MiniDock. Compose la
# sustituye por http://caddy dentro de la red Docker.
# Vacío: usa MINIDOCK_DOMAIN.
MINIDOCK_ADMIN_DOMAIN=
MINIDOCK_PROXY_URL=http://localhost
# Private JSON Admin API of Caddy. Compose pins this address on an internal
# network and does not expose it to the host.
MINIDOCK_CADDY_ADMIN_URL=http://127.0.0.1:2019
# Contrato de la sonda externa de Caddy: sólo un estado y, opcionalmente, un
# fragmento de respuesta coincidente permiten declarar la ruta saludable.
MINIDOCK_PROXY_EXPECTED_STATUS=200
MINIDOCK_PROXY_EXPECTED_CONTENT=
MINIDOCK_BACKUP_PATH=./data/backups
MINIDOCK_BACKUP_INTERVAL=24h
MINIDOCK_BACKUP_RETENTION=7
# local conserva las copias cifradas en MINIDOCK_BACKUP_PATH. Usa s3 para AWS
# o MinIO; el endpoint de MinIO debe incluir esquema, por ejemplo
# http://minio:9000. Las credenciales deben inyectarse desde un gestor de
# secretos, no versionarse en este archivo.
MINIDOCK_BACKUP_PROVIDER=local
MINIDOCK_BACKUP_S3_ENDPOINT=
MINIDOCK_BACKUP_S3_REGION=us-east-1
MINIDOCK_BACKUP_S3_BUCKET=
MINIDOCK_BACKUP_S3_PREFIX=minidock
MINIDOCK_BACKUP_S3_ACCESS_KEY=
MINIDOCK_BACKUP_S3_SECRET_KEY=
MINIDOCK_SLO_BUILD_DURATION_MINUTES=10
# Ventana de cálculo basada en el historial de sondas externas.
MINIDOCK_SLO_PROBE_WINDOW=24h
# Control plane de agentes (opcional). Expón esta dirección únicamente dentro
# de WireGuard; el servidor exige TLS 1.3 con certificado de cliente. No hay
# fallback a SSH ni a conexiones sin mTLS.
MINIDOCK_AGENT_ADDRESS=
MINIDOCK_AGENT_TLS_CERTIFICATE_PATH=
MINIDOCK_AGENT_TLS_PRIVATE_KEY_PATH=
MINIDOCK_AGENT_TLS_CLIENT_CA_PATH=
# Solo Compose: ruta del host montada en /repos dentro del contenedor.
MINIDOCK_LOCAL_REPOSITORIES_PATH_HOST=./repositories
